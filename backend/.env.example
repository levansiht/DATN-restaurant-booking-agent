# Database Configuration
POSTGRES_DB=ai_chat_bot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Django Configuration
APPLICATION_SECRET=change-me
DEBUG=True
USE_ENV_FILE=.env
WEBSITE_NAME="PSCD Japanese Dining"
WEBSITE_URL=http://localhost:5173
BACKEND_URL=http://localhost:8001

# Sepay Payment Gateway
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
SEPAY_ENVIRONMENT=sandbox
SEPAY_SUCCESS_URL=http://localhost:5173/success.html
SEPAY_ERROR_URL=http://localhost:5173/error.html
SEPAY_CANCEL_URL=http://localhost:5173/cancel.html

# n8n admin notifications
N8N_ADMIN_NOTIFICATIONS_ENABLED=1
N8N_ADMIN_WEBHOOK_URL=http://localhost:5678/webhook/restaurant-admin-notify
N8N_ADMIN_WEBHOOK_SECRET=change-this-n8n-secret
N8N_ADMIN_WEBHOOK_TIMEOUT_SECONDS=5

# Optional n8n channel credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_ADMIN_PSID=

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=True
SMTP_FROM="PSCD Japanese Dining <no-reply@example.com>"

# AI API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# JWT/Auth
ACCESS_TOKEN_LIFETIME=24
REFRESH_TOKEN_LIFETIME=168
PASSWORD_RESET_TIMEOUT=3600

# Optional
THROTTLE_RATES_ANON=100/hour
THROTTLE_RATES_USER=1000/hour
USER_RESET_PASSWORD_CALLBACK_URL=http://localhost:5173/reset-password
USER_VERIFY_EMAIL_CALLBACK_URL=http://localhost:5173/verify-email
EMAIL_CRYPTER_FIELD_KEY=change-me-32-chars-min
IS_DISPLAY_SWAGGER=1
